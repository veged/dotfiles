#!/usr/bin/env zsh

emulate -LR zsh
set -euo pipefail

repo_root=${0:A:h:h}
SCRIPT_NAME=install-mcp
source "$repo_root/scripts/lib/install-common.zsh"

manifest_path="$repo_root/ai/mcp.json"
cursor_dir="$HOME/.cursor"
cursor_manifest_path="$cursor_dir/mcp.json"
claude_dir="$HOME/.claude"
claude_template_path="$repo_root/claude/.settings.template.json"
claude_settings_path="$claude_dir/settings.json"
codex_dir="$HOME/.codex"
codex_template_path="$repo_root/codex/.config.template.toml"
codex_config_path="$codex_dir/config.toml"
opencode_dir="$HOME/.config/opencode"
opencode_template_path="$repo_root/config/opencode/.opencode.template.jsonc"
opencode_config_path="$opencode_dir/opencode.jsonc"
mode=default

if (( $# > 1 )); then
  die "install-mcp: expected at most one mode argument"
fi

if (( $# == 1 )); then
  case "$1" in
    --sync-only|--tools-only|--check)
      mode=$1
      ;;
    *)
      die "install-mcp: unknown argument: $1"
      ;;
  esac
fi

require_commands diff jq
[[ -f "$manifest_path" ]] || die "install-mcp: missing manifest: $manifest_path"

jq '
  to_entries[]
  | select(.value.transport == "local" and ((.value.install // {}) | has("check_path")))
  | if .value.command != .value.install.check_path then
      error("install-mcp: install.check_path must match command for " + .key)
    else
      empty
    end
' "$manifest_path" >/dev/null

run_install_command() {
  local name=$1
  local -a argv=()
  local arg

  while IFS= read -r arg; do
    argv+=("$arg")
  done < <(jq -r --arg name "$name" '.[$name].install.argv[]?' "$manifest_path")

  (( ${#argv[@]} > 0 )) || die "install-mcp: missing install.argv for $name"
  "${argv[@]}"
}

runtime_exists() {
  local target=$1

  if [[ "$target" == */* ]]; then
    [[ -x "$target" ]]
    return
  fi

  command -v "$target" >/dev/null 2>&1
}

install_local_tools() {
  local name check_path

  while IFS= read -r name; do
    [[ -n "$name" ]] || continue

    check_path=$(jq -r --arg name "$name" '.[$name].install.check_path // .[$name].command' "$manifest_path")
    runtime_exists "$check_path" && continue

    print "install-mcp: installing local runtime: $name"
    run_install_command "$name"
    runtime_exists "$check_path" || die "install-mcp: install command did not produce runtime for $name: $check_path"
  done < <(
    jq -r '
      to_entries[]
      | select(.value.enabled and .value.transport == "local" and ((.value.install // {} | .kind) == "command"))
      | .key
    ' "$manifest_path"
  )
}

check_local_tools() {
  local runtime_path missing=0

  while IFS= read -r runtime_path; do
    [[ -n "$runtime_path" ]] || continue

    if ! runtime_exists "$runtime_path"; then
      print -u2 "install-mcp: missing local MCP runtime: $runtime_path"
      missing=1
    fi
  done < <(
    jq -r '
      to_entries[]
      | select(.value.enabled and .value.transport == "local")
      | (.value.install.check_path // .value.command)
    ' "$manifest_path"
  )

  (( missing == 0 )) || return 1
}

check_generated_file() {
  local expected_path=$1
  local live_path=$2

  [[ -f "$live_path" ]] || die "install-mcp: missing generated file: $live_path"
  diff -u "$expected_path" "$live_path"
}

check_generated_files() {
  local tmpdir tmp_home

  tmpdir=$(make_tmpdir install-mcp-check)

  (
    trap 'rm -rf "$tmpdir"' EXIT
    tmp_home="$tmpdir/home"

    mkdir -p \
      "$tmp_home/.cursor" \
      "$tmp_home/.claude" \
      "$tmp_home/.codex" \
      "$tmp_home/.config/opencode"

    if [[ -f "$opencode_config_path" ]]; then
      cp "$opencode_config_path" "$tmp_home/.config/opencode/opencode.jsonc"
    fi

    HOME="$tmp_home" zsh "$repo_root/scripts/install-mcp" --sync-only >/dev/null

    check_generated_file "$tmp_home/.cursor/mcp.json" "$cursor_manifest_path"
    check_generated_file "$tmp_home/.claude/settings.json" "$claude_settings_path"
    check_generated_file "$tmp_home/.codex/config.toml" "$codex_config_path"
    check_generated_file "$tmp_home/.config/opencode/opencode.jsonc" "$opencode_config_path"
  )
}

case "$mode" in
  --tools-only)
    install_local_tools
    exit 0
    ;;
  --check)
    check_local_tools
    check_generated_files
    exit 0
    ;;
esac

if [[ "$mode" == "default" ]]; then
  install_local_tools
fi

[[ -f "$claude_template_path" ]] || die "install-mcp: missing claude template: $claude_template_path"
[[ -f "$codex_template_path" ]] || die "install-mcp: missing codex template: $codex_template_path"
[[ -f "$opencode_template_path" ]] || die "install-mcp: missing opencode template: $opencode_template_path"

mkdir -p "$cursor_dir"
mkdir -p "$claude_dir"
mkdir -p "$codex_dir"
mkdir -p "$opencode_dir"

jq '
  def cursor_base($server):
    {
      type: (($server.clients // {} | .cursor // {} | .type) // "streamable-http"),
      url: $server.url,
      disabled: ($server.enabled | not),
      headers: (
        $server.auth // {} |
        if .type == "bearer_env" then
          {Authorization: ("Bearer ${env:" + .env + "}")}
        else
          {}
        end
      ),
      disabledTools: (($server.clients // {} | .cursor // {} | .disabledTools) // []),
      timeout: (($server.clients // {} | .cursor // {} | .timeout) // 60),
      alwaysAllow: (($server.clients // {} | .cursor // {} | .alwaysAllow) // [])
    };

  def render_server($name; $server):
    if $server.transport == "local" then
      {
        key: $name,
        value: {
          command: $server.command,
          args: ($server.args // []),
          disabled: ($server.enabled | not)
        }
      }
    elif $server.transport == "remote" then
      {
        key: $name,
        value: cursor_base($server)
      }
    else
      error("install-mcp: unsupported transport for " + $name)
    end;

  {
    mcpServers: (
      to_entries
      | map(render_server(.key; .value))
      | from_entries
    )
  }
' "$manifest_path" > "$cursor_manifest_path"

jq -s '
  def derived_claude_allow_tools($manifest):
    reduce (
      $manifest
      | to_entries[]
      | select(.value.enabled)
      | (((.value.clients // {} | .claude // {} | .allow_tools) // [])[])
    ) as $item (
      [];
      if index($item) then
        .
      else
        . + [$item]
      end
    );

  def drop_mcp_allow_entries($items):
    ($items // [])
    | map(select((type != "string") or (startswith("mcp__") | not)));

  .[0] as $manifest
  | .[1]
  | .permissions = ((.permissions // {})
      | .allow = (drop_mcp_allow_entries(.allow) + derived_claude_allow_tools($manifest)))
' "$manifest_path" "$claude_template_path" > "$claude_settings_path"

codex_marker_count=$(grep -Fxc '# __MCP_SERVERS__' "$codex_template_path" || true)
if [[ "$codex_marker_count" -eq 0 ]]; then
  die "install-mcp: missing codex marker in template: $codex_template_path"
fi
if [[ "$codex_marker_count" -ne 1 ]]; then
  die "install-mcp: expected exactly one codex marker in template: $codex_template_path"
fi

codex_fragment_path=$(mktemp "${TMPDIR:-/tmp}/codex-mcp.XXXXXX")

jq -r '
  def toml_array($items):
    "[" + (($items // []) | map(@json) | join(", ")) + "]";

  def codex_tool_approvals($name; $server):
    (
      (($server.clients // {} | .codex // {} | .tool_approvals) // {})
      | to_entries
      | map(
          "",
          "[mcp_servers.\($name).tools.\(.key)]",
          "approval_mode = \(.value | @json)"
        )
      | flatten
      | join("\n")
    );

  def codex_server($name; $server):
    if ($server.enabled | not) then
      empty
    elif $server.transport == "local" then
      [
        "[mcp_servers.\($name)]",
        "command = \($server.command | @json)"
      ]
      + (if (($server.args // []) | length) > 0 then ["args = \(toml_array($server.args))"] else [] end)
      + [codex_tool_approvals($name; $server)]
      | map(select(length > 0))
      | join("\n")
    elif $server.transport == "remote" then
      [
        "[mcp_servers.\($name)]",
        "url = \($server.url | @json)"
      ]
      + (
          if (($server.auth // {} | .type) == "bearer_env") then
            ["bearer_token_env_var = \($server.auth.env | @json)"]
          else
            []
          end
        )
      + [codex_tool_approvals($name; $server)]
      | map(select(length > 0))
      | join("\n")
    else
      error("install-mcp: unsupported transport for " + $name)
    end;

  [
    to_entries[]
    | codex_server(.key; .value)
  ] | join("\n\n")
' "$manifest_path" > "$codex_fragment_path"

awk -v fragment_path="$codex_fragment_path" '
  $0 == "# __MCP_SERVERS__" {
    while ((getline line < fragment_path) > 0) {
      print line
    }
    close(fragment_path)
    next
  }
  { print }
' "$codex_template_path" > "$codex_config_path"

rm -f "$codex_fragment_path"

opencode_marker_count=$(grep -Fc '"mcp": __MCP_JSON__' "$opencode_template_path" || true)
if [[ "$opencode_marker_count" -eq 0 ]]; then
  die "install-mcp: missing opencode marker in template: $opencode_template_path"
fi
if [[ "$opencode_marker_count" -ne 1 ]]; then
  die "install-mcp: expected exactly one opencode marker in template: $opencode_template_path"
fi

opencode_fragment_path=$(mktemp "${TMPDIR:-/tmp}/opencode-mcp.XXXXXX")
opencode_base_path=$(mktemp "${TMPDIR:-/tmp}/opencode-base.XXXXXX")

jq '
  def opencode_local($server):
    {
      enabled: $server.enabled,
      type: "local",
      command: ([$server.command] + ($server.args // []))
    };

  def opencode_remote($server):
    {
      enabled: $server.enabled,
      type: (($server.clients // {} | .opencode // {} | .type) // "remote"),
      url: $server.url
    }
    + (
        $server.auth // {} |
        if .type == "bearer_env" then
          {headers: {Authorization: ("Bearer {env:" + .env + "}")}}
        else
          {}
        end
      )
    + (
        ($server.clients // {} | .opencode // {})
        | if has("timeout") then
            {timeout: .timeout}
          else
            {}
          end
      );

  {
    mcp: (
      to_entries
      | map(
          if .value.transport == "local" then
            {
              key: .key,
              value: opencode_local(.value)
            }
          elif .value.transport == "remote" then
            {
              key: .key,
              value: opencode_remote(.value)
            }
          else
            error("install-mcp: unsupported transport for " + .key)
          end
        )
      | from_entries
    )
  }.mcp
' "$manifest_path" > "$opencode_fragment_path"

if [[ -n ${ELIZA_API_HOST-} || ! -f "$opencode_config_path" ]]; then
  awk -v eliza_api_host="${ELIZA_API_HOST-}" '
    {
      if (length(eliza_api_host) > 0) {
        gsub(/ELIZA_API_HOST/, eliza_api_host)
      }
      gsub(/__MCP_JSON__/, "{}")
      print
    }
  ' "$opencode_template_path" > "$opencode_base_path"
else
  awk '
    {
      gsub(/__MCP_JSON__/, "{}")
      print
    }
  ' "$opencode_template_path" > "$opencode_base_path"

  jq -s '
    reduce (
      (.[1].provider // {})
      | to_entries[]
      | select((.value.options // {}) | has("baseURL"))
    ) as $provider (
      .[0];
      if (((.provider // {}) | has($provider.key)) and ((.provider[$provider.key].options // {}) | has("baseURL"))) then
        .provider[$provider.key].options.baseURL = $provider.value.options.baseURL
      else
        .
      end
    )
  ' "$opencode_base_path" "$opencode_config_path" > "$opencode_base_path.tmp"
  mv "$opencode_base_path.tmp" "$opencode_base_path"
fi

jq --slurpfile mcp "$opencode_fragment_path" '
  .mcp = $mcp[0]
' "$opencode_base_path" > "$opencode_config_path"

rm -f "$opencode_fragment_path" "$opencode_base_path"

print "install-mcp: synced ~/.cursor/mcp.json"
print "install-mcp: synced ~/.claude/settings.json"
print "install-mcp: synced ~/.codex/config.toml"
print "install-mcp: synced ~/.config/opencode/opencode.jsonc"
