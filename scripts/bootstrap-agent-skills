#!/usr/bin/env zsh

emulate -LR zsh
set -euo pipefail

repo_root=${0:A:h:h}
SCRIPT_NAME=bootstrap-agent-skills
source "$repo_root/scripts/lib/install-common.zsh"
source "$repo_root/scripts/lib/agent-skills-layer.zsh"

usage() {
  cat <<'EOF'
Usage: ./scripts/bootstrap-agent-skills

Projects the canonical ~/.agents/skills layer into assistant-specific discovery
directories and migrates known shared bundles from ~/.codex/skills into the
canonical layer when needed.
EOF
}

while (( $# > 0 )); do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    *)
      die "bootstrap-agent-skills: unknown argument: $1"
      ;;
  esac
done

require_commands diff

agent_skills_reconcile_layer

print "bootstrap-agent-skills: projected canonical skills"
