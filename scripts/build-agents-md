#!/usr/bin/env zsh

emulate -LR zsh
set -euo pipefail

repo_root=${0:A:h:h}
SCRIPT_NAME=build-agents-md
source "$repo_root/scripts/lib/install-common.zsh"

claude_md="$repo_root/claude/CLAUDE.md"
agents_md="$repo_root/codex/AGENTS.md"

[[ -f "$claude_md" ]] || die "$SCRIPT_NAME: missing $claude_md"

typeset -a sources
while IFS= read -r line; do
  [[ "$line" == @* ]] || continue
  raw="${line#@}"
  expanded="${raw/#\~\//$HOME/}"
  resolved="${expanded:A}"
  [[ -f "$resolved" ]] || die "$SCRIPT_NAME: import target not found: $expanded"
  sources+=("$resolved")
done < "$claude_md"

(( ${#sources[@]} > 0 )) || die "$SCRIPT_NAME: no @-imports found in $claude_md"

tmp=$(mktemp "${TMPDIR:-/tmp}/agents-md.XXXXXX")
{
  print -- "<!-- GENERATED by scripts/build-agents-md from claude/CLAUDE.md @-imports."
  print -- "     Do not edit by hand. Re-run: ./scripts/install-mcp --sync-only -->"
  print
  first=1
  for f in "${sources[@]}"; do
    (( first )) || print
    cat "$f"
    first=0
  done
} > "$tmp"

if [[ -f "$agents_md" ]] && diff -q "$agents_md" "$tmp" >/dev/null 2>&1; then
  rm -f "$tmp"
  print "$SCRIPT_NAME: $agents_md is up to date"
else
  mv "$tmp" "$agents_md"
  print "$SCRIPT_NAME: wrote $agents_md (${#sources[@]} sources)"
fi
