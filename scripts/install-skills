#!/usr/bin/env zsh

emulate -LR zsh
set -euo pipefail

repo_root=${0:A:h:h}
SCRIPT_NAME=install-skills
source "$repo_root/scripts/lib/install-common.zsh"
source "$repo_root/scripts/lib/skill-acquisition.zsh"
source "$repo_root/scripts/lib/agent-skills-layer.zsh"

ACQUISITION_SOURCE_BASE_DIR="$repo_root"
skills_root="$repo_root/ai/skills"
registry_path="$skills_root/skills.json"
force=0

usage() {
  cat <<'EOF'
Usage: ./scripts/install-skills [--update|--force]

Syncs local skill packages from ai/skills/* and external skill dependencies from
ai/skills/skills.json into ~/.agents/skills, then refreshes assistant-specific
discovery layers.

Options:
  --update, --force  Reinstall external skills from sources before syncing.
EOF
}

while (( $# > 0 )); do
  case "$1" in
    --update|--refresh)
      force=1
      ;;
    --force)
      force=1
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      die "install-skills: unknown argument: $1"
      ;;
  esac
  shift
done

require_commands jq npx fd diff

mkdir -p "$AGENT_SKILLS_CANONICAL_DIR"

tmpdir=$(make_tmpdir dotfiles-skills)
trap 'rm -rf "$tmpdir"' EXIT

typeset -A local_skill_dirs external_skill_sources
typeset -Ua managed_names
managed_names=()
source_index=0

sync_local_skill_dir() {
  local target_dir=$1
  local source_dir=$2

  if [[ -L "$source_dir" ]]; then
    rm -rf "$target_dir"
    ln -s "${source_dir:A}" "$target_dir"
    return
  fi

  replace_dir "$target_dir" "$source_dir"
}

register_external_skill() {
  local name=$1
  local source=$2

  [[ -n "$name" ]] || die "install-skills: empty external skill name from source: $source"

  if [[ -n ${local_skill_dirs[$name]-} ]]; then
    die "install-skills: skill name conflict: external skill '$name' from $source conflicts with local skill at ${local_skill_dirs[$name]}"
  fi

  if [[ -n ${external_skill_sources[$name]-} ]]; then
    die "install-skills: skill name conflict: external skill '$name' from $source conflicts with ${external_skill_sources[$name]}"
  fi

  external_skill_sources[$name]=$source
}

for skill_dir in "$skills_root"/*(N-/); do
  [[ -f "$skill_dir/SKILL.md" ]] || continue

  name=${skill_dir:t}
  local_skill_dirs[$name]=$skill_dir
  sync_local_skill_dir "$AGENT_SKILLS_CANONICAL_DIR/$name" "$skill_dir"
  managed_names+=("$name")
done

if [[ -f "$registry_path" ]]; then
  skill_entries=("${(@f)$(acquisition_skill_specs "$registry_path")}")

  for entry in "${skill_entries[@]}"; do
    source=$(jq -r '.source' <<<"$entry")
    install_all=$(jq -r 'if .install_all then 1 else 0 end' <<<"$entry")
    selected_skills=("${(@f)$(acquisition_spec_skills "$entry")}")
    stage_dir="$tmpdir/source-$source_index"
    ((source_index += 1))

    requested_names=("${selected_skills[@]}")
    (( install_all || ${#requested_names[@]} )) || die "install-skills: empty skill list for source: $source"

    if (( install_all )); then
      print "install-skills: fetching: $source"
      acquisition_stage_skills "$stage_dir" "$source" "${selected_skills[@]}"

      staged_paths=("${(@f)$(acquisition_staged_skill_paths "$stage_dir")}")
      (( ${#staged_paths[@]} )) || die "install-skills: no skills staged for source: $source"

      for skill_path in "${staged_paths[@]}"; do
        name=${skill_path:t}
        register_external_skill "$name" "$source"
        if [[ -L "$AGENT_SKILLS_CANONICAL_DIR/$name" ]]; then
          print "install-skills: local override: $name"
          managed_names+=("$name")
          continue
        fi
        replace_dir "$AGENT_SKILLS_CANONICAL_DIR/$name" "$skill_path"
        managed_names+=("$name")
      done
      continue
    fi

    for name in "${requested_names[@]}"; do
      register_external_skill "$name" "$source"
    done

    # A manual symlink at the canonical dir is a local dev override — keep it as-is.
    typeset -a override_names install_names
    override_names=()
    install_names=()
    for name in "${requested_names[@]}"; do
      if [[ -L "$AGENT_SKILLS_CANONICAL_DIR/$name" ]]; then
        override_names+=("$name")
      else
        install_names+=("$name")
      fi
    done

    if (( ${#override_names[@]} )); then
      print "install-skills: local override: ${override_names[*]}"
      managed_names+=("${override_names[@]}")
    fi

    (( ${#install_names[@]} )) || continue

    needs_install=$force
    if (( ! needs_install )); then
      for name in "${install_names[@]}"; do
        [[ -d "$AGENT_SKILLS_CANONICAL_DIR/$name" ]] || { needs_install=1; break; }
      done
    fi

    if (( ! needs_install )); then
      managed_names+=("${install_names[@]}")
      print "install-skills: already present: $source"
      continue
    fi

    print "install-skills: fetching: $source"
    acquisition_stage_skills "$stage_dir" "$source" "${install_names[@]}"

    for name in "${install_names[@]}"; do
      [[ -d "$stage_dir/.agents/skills/$name" ]] || die "install-skills: staged skill not found: $source#$name"
      replace_dir "$AGENT_SKILLS_CANONICAL_DIR/$name" "$stage_dir/.agents/skills/$name"
      managed_names+=("$name")
    done
  done
fi

agent_skills_append_preserved_bundles managed_names

prune_dir_except "$AGENT_SKILLS_CANONICAL_DIR" "${managed_names[@]}"

agent_skills_reconcile_layer

print "install-skills: synced ${#managed_names[@]} skills"
